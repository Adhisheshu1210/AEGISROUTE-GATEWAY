# Application Core Settings
APP_NAME="AegisRoute-Enterprise-Backend"
APP_ENV="development"
PORT=8000
HOST="0.0.0.0"

# Gemini Enterprise Key
GEMINI_API_KEY=""

# Database Connections (If persistent SQL is used)
DATABASE_URL="postgresql://user:password@localhost:5432/aegisroute"

# NVIDIA RAPIDS GPU Settings
CUDA_VISIBLE_DEVICES="0"
ENABLE_GPU_ACCELERATION=true
